# L Health — environment variable template.
# Copy to `.dev.vars` for local dev; set production values as Wrangler secrets
# (`wrangler secret put <NAME>`). NEVER commit real secret values.

# Better Auth — signing secret for sessions/cookies.
# Generate a strong value, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL the app is served from (auth callbacks/cookies).
# Local dev: http://localhost:3000 ; production: your deployed Worker URL.
BETTER_AUTH_URL=http://localhost:3000
