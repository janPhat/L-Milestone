# L Health — environment variable template.
# Copy to `.dev.vars` for local dev; set production values as Wrangler secrets
# (`wrangler secret put <NAME>`). NEVER commit real secret values.

# Better Auth — signing secret for sessions/cookies.
# Generate a strong value, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL the app is served from (auth callbacks/cookies).
# Local dev: http://localhost:3000 ; production: your deployed Worker URL.
BETTER_AUTH_URL=http://localhost:3000

# Invite-only registration gate. Sign-up requires this exact code (sent as the
# x-invite-code header). Fail-closed: if unset, all sign-ups are blocked.
INVITE_CODE=

# Resend — transactional email (password reset + verification).
# Create a key at resend.com and set it as a Worker secret (wrangler secret put).
# RESEND_FROM is optional; defaults to the Resend onboarding sender, which only
# delivers to your own Resend account email until you verify a sending domain.
RESEND_API_KEY=
RESEND_FROM=
